# ============================================================================
# Easy PDF — environment variables
# Copy to `.env` and adjust as needed. docker-compose.yml reads from here.
# ============================================================================

# Upload cap (bytes). Default 100 MB. Stay below 200 MB unless you also raise
# timeouts and memory; gs can spike to ~4× input size while compressing.
MAX_UPLOAD_BYTES=104857600

# Per-tool timeouts (seconds). These kill the subprocess (SIGTERM → SIGKILL)
# if it exceeds the budget. Worst case: 100 MB scanned PDF at /printer on a
# slow CPU can take ~5 min, so keep this generous.
GS_TIMEOUT_SECONDS=300
# OCRmyPDF at --optimize 2 on a 17 MB scanned CV took ~459 s on a single
# probe (137 pages). 900 s leaves headroom for 50–100 MB scans on slower
# hardware. Bump further only after profiling.
OCR_TIMEOUT_SECONDS=900
FOLIATE_TIMEOUT_SECONDS=60
PAGES_TIMEOUT_SECONDS=60

# How long Redis keeps job state and the resulting PDF on disk before cleanup.
JOB_TTL_SECONDS=86400

# Rate limiting — applied to the 4 `POST /api/jobs/*` endpoints.
# Fixed window per client IP. Quota is consumed only AFTER upload
# validation passes (size, PDF magic, required fields), so a bad
# upload never burns the bucket.
# Set RATE_LIMIT_ENABLED=false to disable the limit entirely (e.g.
# for local development or trusted-network deployments).
RATE_LIMIT_ENABLED=true
RATE_LIMIT_JOBS_PER_MINUTE=5
RATE_LIMIT_JOBS_PER_HOUR=30
RATE_LIMIT_MAX_ACTIVE_JOBS_PER_IP=3

# Trust the `X-Forwarded-For` header. ONLY enable this when the API
# sits behind a reverse proxy (nginx, Caddy, ALB, ...) that strips
# client-supplied XFF and re-injects the real client IP. Leaving this
# off means we use `request.client.host` directly, which an attacker
# cannot spoof.
TRUST_PROXY_HEADERS=false

# Cleanup worker — periodic garbage collector for `/data/inputs`,
# `/data/outputs`, and `/data/extra-inputs`. Runs every
# `CLEANUP_INTERVAL_SECONDS`, reaping `done`/`failed` jobs older than
# `JOB_TTL_SECONDS` and orphan dirs (no Redis key) older than
# `CLEANUP_GRACE_SECONDS`. Never touches `queued`/`processing` jobs.
CLEANUP_INTERVAL_SECONDS=300
CLEANUP_GRACE_SECONDS=3600

# structlog level. Use DEBUG for development, INFO for production.
LOG_LEVEL=INFO
